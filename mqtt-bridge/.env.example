# SmokeSense MQTT Bridge — Environment Variables

# Supabase (required)
SUPABASE_URL=https://txhvtwlifuoqqnxhegfz.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key

# MQTT Broker
MQTT_BROKER_URL=mqtt://your-mosquitto.railway.app:1883
MQTT_USERNAME=bridge
MQTT_PASSWORD=SmokeSense_Bridge_2026!
MQTT_TOPIC_PREFIX=smokesense

# Server
PORT=3500
LOG_LEVEL=info

# ── Alert Notifications ──────────────────────────

# SendGrid (email alerts)
SENDGRID_API_KEY=SG.your_sendgrid_api_key
SENDGRID_FROM_EMAIL=alerts@arcticengineering.co.za

# Twilio (SMS alerts)
TWILIO_ACCOUNT_SID=AC_your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890

# Alert recipients (comma-separated)
ALERT_EMAILS=rigard@arcticengineering.co.za
ALERT_SMS_NUMBERS=+27821234567

# Alert thresholds
EMAIL_MIN_SEVERITY=2
SMS_MIN_SEVERITY=3
ALERT_COOLDOWN_MS=300000
